# Copy this file to `.env` and fill in the values. `.env` is git-ignored
# (see .gitignore) — never commit real secrets. If any secret below was ever
# committed to version control, rotate it (see SECURITY.md).

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, or any Postgres provider).
# Lightsprint-managed repos get this automatically — no manual setup needed.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Auth.js secret for signing JWTs and encrypting sessions. Must be a
# high-entropy random string; rotating it invalidates all existing sessions.
# Lightsprint-managed repos get this automatically.
# For local dev, generate one: `openssl rand -base64 32`
# (or https://generate-secret.vercel.app/32)
AUTH_SECRET=

# ── Optional ────────────────────────────────────────────────────────────────

# Shared password for the four seeded login accounts (`bun run db:seed`).
# Defaults to the well-known value "password" if unset — SET THIS to a strong
# value before any non-demo use, and change the accounts' passwords afterwards.
SEED_PASSWORD=

# The exact origin (or bare host) this deployment is served from, e.g.
# `https://myapp-3000.lightsprint.ai`. It scopes the Server Actions CSRF
# allowlist to this single host in production instead of the shared
# `*.lightsprint.ai` / `*.e2b.app` multi-tenant wildcards. Lightsprint-managed
# repos get this automatically. Leave unset for local dev — the broad preview
# wildcards are used only as a non-production fallback.
PREVIEW_ORIGIN=

# Backing store for the auth-endpoint rate limiter (lib/rate-limit.ts).
#   postgres → shared, cross-instance store (the scalable production path; needs
#              DATABASE_URL). This is the default whenever DATABASE_URL is set.
#   memory   → per-process in-memory store (local dev / tests only; the limit is
#              per-instance, not global).
# Leave unset to auto-select: Postgres when DATABASE_URL is set, else in-memory.
RATE_LIMIT_STORE=

# Dedicated database for the integration (`bun run test:integration`) and e2e
# (`bun run test:e2e`) suites. Point this at an ISOLATED, throwaway database so
# tests never touch development data. When unset, the integration harness falls
# back to DATABASE_URL but runs only rollback-isolated work (never a destructive
# TRUNCATE) against it; e2e uses DATABASE_URL as-is. See test/README.md.
TEST_DATABASE_URL=
